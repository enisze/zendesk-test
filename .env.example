# Zendesk subdomain (the "acme" in https://acme.zendesk.com)
ZENDESK_SUBDOMAIN=acme

# Zendesk email address used to authenticate
ZENDESK_EMAIL=agent@example.com

# Zendesk API token (Admin Center > Apps and integrations > APIs > Zendesk API)
ZENDESK_API_TOKEN=changeme

# Numeric ID of the demo user whose CC'd tickets we list and modify.
DEMO_USER_ID=123456789
