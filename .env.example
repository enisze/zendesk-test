# Full Zendesk API base URL, including /api/v2
# e.g. https://con-leafworks2.zendesk.com/api/v2
ZENDESK_BASE_URL=https://your-subdomain.zendesk.com/api/v2

# Bearer token sent as `Authorization: Bearer <token>`
ZENDESK_API_TOKEN=changeme

# Numeric ID of the demo user whose CC'd tickets we list and modify.
DEMO_USER_ID=123456789
